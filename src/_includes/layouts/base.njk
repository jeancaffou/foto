<!doctype html>
<html lang="{{ pageLanguage or 'en' }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="#080a0a">
    <meta name="description" content="{{ (metaDescription or 'Aerial, cave and nature photo stories by Žan Kafol, a photographer and software engineer based in Postojna, Slovenia.') | escape }}">
    <meta property="og:title" content="{{ (title or 'Žan Kafol — Aerial & Cave Photographer') | escape }}">
    <meta property="og:description" content="{{ (metaDescription or 'Photo stories shaped by flight, caves and the karst landscape.') | escape }}">
    <meta property="og:image" content="{{ (ogImage or '/assets/images/featured/full/20210228-DJI_0270-Pano.webp') | escape }}">
    <title>{{ (title or site.name) | escape }}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>Ž</text></svg>">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Jost:wght@300..700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/assets/css/site.css?v=20260717e">
    {% if blogStyles %}<link rel="stylesheet" href="/assets/css/blog.css?v=20260717e">{% endif %}
    {% if galleryStyles %}<link rel="stylesheet" href="/assets/css/gallery.css?v=20260717e">{% endif %}
    {% if pressStyles %}<link rel="stylesheet" href="/assets/css/press.css?v=20260717e">{% endif %}
    <script src="/assets/js/site.js?v=20260717e" defer></script>
    {% if galleryStyles %}<script src="/assets/js/gallery.js?v=20260717e" defer></script>{% endif %}
  </head>
  <body class="{{ bodyClass or '' }}">
    <a class="skip-link" href="#main">Skip to content</a>
    {{ content | safe }}
  </body>
</html>
