---
layout: layouts/base.njk
permalink: /press/index.html
pressStyles: true
bodyClass: press-archive-page
pageLanguage: en
title: Press & interviews — Žan Kafol
metaDescription: Interviews, television appearances, radio conversations and published features with Žan Kafol.
---
<header class="site-header" data-header>
  <a class="brand" href="/" aria-label="Žan Kafol, home">
    <span class="brand__name">Žan Kafol</span>
    <span class="brand__role">{{ site.eyebrow }}</span>
  </a>

  <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="site-nav">
    <span class="menu-toggle__label">Menu</span>
    <span class="menu-toggle__lines" aria-hidden="true"></span>
  </button>

  <nav class="site-nav" id="site-nav" aria-label="Primary navigation">
    <a href="/#work">Work</a>
    <a href="/#about">About</a>
    <a href="/#featured">Featured</a>
    <a href="/press/" aria-current="page">Press</a>
    <a href="/#contact">Contact</a>
  </nav>
</header>

<main id="main" class="press-archive">
  <header class="press-archive__header shell">
    <p class="section-label">Press archive</p>
    <div class="press-archive__intro">
      <h1>Press &amp;<br>interviews</h1>
      <p>Television appearances, radio conversations and published profiles covering photography, paragliding, caves and the karst landscape.</p>
    </div>
  </header>

  <section class="press-archive__listing shell" aria-label="Press and interview features">
    {% for item in site.press %}
    <article class="press-archive-card">
      <a href="{{ item.url }}">
        <figure class="press-archive-card__image">
          <img src="{{ item.image }}" alt="" loading="{% if loop.index <= 4 %}eager{% else %}lazy{% endif %}" decoding="async">
          <span class="press-archive-card__kind">{% if item.kind == "video" %}Video{% elif item.kind == "audio" %}Radio{% elif item.kind == "award" %}Recognition{% else %}Article{% endif %}</span>
        </figure>
        <div class="press-archive-card__body">
          <p class="press-archive-card__meta"><span>{{ item.source }}</span><time>{{ item.year }}</time></p>
          <h2>{{ item.title }}</h2>
          <p class="press-archive-card__description">{{ item.description }}</p>
          <span class="press-archive-card__read">View feature <span aria-hidden="true">→</span></span>
        </div>
      </a>
    </article>
    {% endfor %}
  </section>
</main>

<footer class="site-footer" id="contact">
  <div class="site-footer__inner shell">
    <div class="site-footer__brand">
      <span class="brand__name">Žan Kafol</span>
      <span class="brand__role">{{ site.eyebrow }}</span>
      <p>Photo stories shaped by flight,<br>caves and the karst landscape.</p>
    </div>
    <div class="footer-group">
      <p class="footer-label">Contact</p>
      <a href="mailto:{{ site.email }}">{{ site.email }}</a>
      <span>{{ site.location }}</span>
    </div>
    <div class="footer-group">
      <p class="footer-label">Follow</p>
      <div class="footer-socials">
        {% for item in site.social %}<a href="{{ item.url }}" target="_blank" rel="noreferrer" aria-label="{{ item.label }}"><img src="{{ item.icon }}" alt=""></a>{% endfor %}
      </div>
    </div>
    <div class="site-footer__legal">
      <p>© {% year %} Žan Kafol</p>
      <a href="#main">Back to top ↑</a>
    </div>
  </div>
</footer>
