---
layout: layouts/base.njk
pagination:
  data: featuredPageVariants
  size: 1
  alias: featurePage
permalink: "{{ featurePage.permalink }}"
pressStyles: true
bodyClass: press-detail-page
eleventyComputed:
  pageLanguage: "{{ featurePage.lang }}"
  title: "{{ featurePage.item.title }} — {{ featurePage.item.publication }}"
  metaDescription: "{{ featurePage.item.summary }}"
  alternateUrl: "{{ featurePage.alternateUrl }}"
---
{% set featureItem = featurePage.item %}
{% set pageSite = featurePage.site %}
{% set copy = featurePage.copy %}
{% if featurePage.lang == "sl" %}{% set homeRoot = "/sl/" %}{% set pressRoot = "/sl/press/" %}{% else %}{% set homeRoot = "/" %}{% set pressRoot = "/press/" %}{% endif %}
<header class="site-header" data-header>
  <a class="brand" href="{{ homeRoot }}" aria-label="Žan Kafol, {{ copy.common.home }}">
    <span class="brand__name">Žan Kafol</span>
    <span class="brand__role">{{ pageSite.eyebrow }}</span>
  </a>

  <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="site-nav">
    <span class="menu-toggle__label">{{ copy.common.menu }}</span>
    <span class="menu-toggle__lines" aria-hidden="true"></span>
  </button>

  <nav class="site-nav" id="site-nav" aria-label="{{ copy.common.primaryNavigation }}">
    <a href="{{ homeRoot }}#work">{{ copy.common.nav.work }}</a>
    <a href="{{ homeRoot }}#about">{{ copy.common.nav.about }}</a>
    <a href="{{ homeRoot }}#featured">{{ copy.common.nav.featured }}</a>
    <a href="{{ pressRoot }}">{{ copy.common.nav.press }}</a>
    <a href="{{ homeRoot }}#contact">{{ copy.common.nav.contact }}</a>
    <a class="language-switch" href="{{ featurePage.alternateUrl }}" hreflang="{% if featurePage.lang == 'sl' %}en{% else %}sl{% endif %}" lang="{% if featurePage.lang == 'sl' %}en{% else %}sl{% endif %}" aria-label="{{ copy.common.switchAria }}">{{ copy.common.switchLabel }}</a>
  </nav>
</header>

<main id="main" class="press-detail">
  <article>
    <header class="press-detail__header shell">
      <a class="press-detail__back" href="{{ homeRoot }}#featured">{{ copy.featured.back }}</a>
      <p class="section-label">{{ copy.featured.label }}</p>
      <h1>{{ featureItem.title }}</h1>
      <div class="press-detail__meta">
        <strong>{{ featureItem.publication }}</strong>
        <time datetime="{{ featureItem.date }}">{{ featureItem.displayDate }}</time>
      </div>
      <p class="press-detail__summary">{{ featureItem.summary }}</p>
      <a class="press-detail__source" href="{{ featureItem.originalUrl }}" target="_blank" rel="noreferrer">
        {{ featureItem.originalLabel }} <span aria-hidden="true">↗</span>
      </a>
    </header>

    <div class="press-detail__gallery shell{% if featureItem.images.length == 1 %} press-detail__gallery--single{% endif %}">
      {% for image in featureItem.images %}
      <figure>
        <a href="{{ image.src }}" target="_blank" aria-label="{{ copy.featured.openImage }}">
          <img src="{{ image.src }}" alt="{{ image.alt }}" loading="{% if loop.first %}eager{% else %}lazy{% endif %}" decoding="async">
        </a>
        <figcaption>{{ image.caption }}</figcaption>
      </figure>
      {% endfor %}
    </div>
  </article>
</main>

<footer class="site-footer" id="contact">
  <div class="site-footer__inner shell">
    <div class="site-footer__brand">
      <span class="brand__name">Žan Kafol</span>
      <span class="brand__role">{{ pageSite.eyebrow }}</span>
      <p>{{ copy.common.footerText | safe }}</p>
    </div>
    <div class="footer-group">
      <p class="footer-label">{{ copy.common.contact }}</p>
      <a href="mailto:{{ pageSite.email }}">{{ pageSite.email }}</a>
      <span>{{ pageSite.location }}</span>
    </div>
    <div class="footer-group">
      <p class="footer-label">{{ copy.common.follow }}</p>
      <div class="footer-socials">
        {% for item in pageSite.social %}<a href="{{ item.url }}" target="_blank" rel="noreferrer" aria-label="{{ item.label }}"><img src="{{ item.icon }}" alt=""></a>{% endfor %}
      </div>
    </div>
    <div class="site-footer__legal">
      <p>© {% year %} Žan Kafol</p>
      <a href="{{ homeRoot }}">{{ copy.common.backHome }}</a>
    </div>
  </div>
</footer>
