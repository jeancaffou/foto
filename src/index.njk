---
layout: layouts/base.njk
title: Žan Kafol — Aerial & Cave Photographer
---
<header class="site-header" data-header>
  <a class="brand" href="#top" aria-label="Žan Kafol, home">
    <span class="brand__name">Žan Kafol</span>
    <span class="brand__role">{{ site.eyebrow }}</span>
  </a>

  <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="site-nav">
    <span class="menu-toggle__label">Menu</span>
    <span class="menu-toggle__lines" aria-hidden="true"></span>
  </button>

  <nav class="site-nav" id="site-nav" aria-label="Primary navigation">
    <a href="#work">Work</a>
    <a href="#about">About</a>
    <a href="#featured">Featured</a>
    <a href="#press">Press</a>
    <a href="#contact">Contact</a>
  </nav>
</header>

<main id="main">
  <section class="hero" id="top" aria-labelledby="hero-title">
    <div class="hero__media" aria-hidden="true">
      <div class="hero__image hero__image--aerial"></div>
      <div class="hero__image hero__image--cave"></div>
    </div>
    <div class="hero__shade" aria-hidden="true"></div>
    <div class="hero__content shell" data-reveal>
      <p class="kicker">Stories in two directions</p>
      <h1 id="hero-title">Aerial &amp; cave<br>photography</h1>
      <span class="gold-rule" aria-hidden="true"></span>
      <p class="hero__intro">Stories from above the landscape<br>and beneath the karst.</p>
    </div>
    <a class="hero__scroll" href="#work">
      <span>Explore</span>
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 4v15m-6-6 6 6 6-6"/></svg>
    </a>
  </section>

  <section class="works shell" id="work" aria-labelledby="work-title">
    <p class="section-label" id="work-title" data-reveal>Selected works</p>
    <div class="work-grid">
      {% for work in site.works %}
      <a class="work-card" href="https://blog.kafol.net/" data-reveal style="--delay: {{ loop.index0 * 55 }}ms">
        <figure>
          <img src="{{ work.image }}" alt="{{ work.title }}" loading="{% if loop.index < 5 %}eager{% else %}lazy{% endif %}" style="object-position: {{ work.position }}">
          <figcaption>
            <span class="work-card__title">{{ work.title }}</span>
            <span class="work-card__type">{{ work.type }}</span>
          </figcaption>
        </figure>
      </a>
      {% endfor %}
    </div>
  </section>

  <section class="about section" id="about" aria-labelledby="about-title">
    <div class="about__inner shell">
      <div class="about__portrait" data-reveal>
        <div class="about__halo" aria-hidden="true"></div>
        <img src="/assets/images/headshot-bw.webp" alt="Portrait of Žan Kafol" loading="lazy">
      </div>
      <div class="about__copy" data-reveal>
        <p class="section-label">About</p>
        <h2 id="about-title">Žan Kafol</h2>
        <p class="about__lead">I’m a photographer and software engineer based in Postojna, Slovenia.</p>
        <p>Photography grew alongside paragliding and caving. The camera moves between long views from the air, the darkness of the karst and night landscapes close to home.</p>
        <a class="text-link" href="https://blog.kafol.net/">More photo stories <span aria-hidden="true">→</span></a>
      </div>
      <dl class="about__facts" data-reveal>
        <div>
          <dt>Home</dt>
          <dd>Postojna<br>Slovenia</dd>
        </div>
        <div>
          <dt>Collaboration</dt>
          <dd>Institute for Karst Research<br>ZRC SAZU</dd>
        </div>
        <div>
          <dt>Practice</dt>
          <dd>Aerial, cave, nature<br>and night photography</dd>
        </div>
      </dl>
    </div>
  </section>

  <div class="editorial-band">
    <section class="featured band-section" id="featured" aria-labelledby="featured-title">
      <p class="section-label" id="featured-title">Featured &amp; awarded</p>
      <div class="feature-grid">
        {% for item in site.features %}
        <a class="feature-card" href="{{ item.url }}" target="_blank" rel="noreferrer" data-reveal>
          <span class="feature-card__logo"><img src="{{ item.logo }}" alt="{{ item.name }}"></span>
          <strong>{{ item.title }}</strong>
          <span>{{ item.detail }}</span>
        </a>
        {% endfor %}
      </div>
      <div class="publication-list" data-reveal aria-label="Selected publications">
        <span class="publication-list__label">Published in</span>
        {% for publication in site.publications %}<span class="publication-mark">{{ publication }}</span>{% endfor %}
      </div>
      <blockquote data-reveal>
        <p>“S svojimi fotografijami želim narediti pozitivno spremembo na tem svetu.”</p>
        <cite>Žan Kafol</cite>
      </blockquote>
    </section>

    <section class="press band-section" id="press" aria-labelledby="press-title">
      <p class="section-label" id="press-title">Press &amp; interviews</p>
      <div class="press-grid">
        {% for item in site.press %}
        <a class="press-card" href="{{ item.url }}" target="_blank" rel="noreferrer" data-reveal>
          <div class="press-card__image">
            <img src="{{ item.image }}" alt="" loading="lazy">
            <span class="play" aria-hidden="true">↗</span>
          </div>
          <div>
            <h3>“{{ item.title }}”</h3>
            <p>{{ item.source }}, {{ item.year }}</p>
          </div>
        </a>
        {% endfor %}
      </div>
    </section>
  </div>

  <section class="journal section shell" aria-labelledby="journal-title">
    <div class="journal__heading" data-reveal>
      <p class="section-label">Photo stories</p>
      <h2 id="journal-title">From the journal</h2>
      <a class="text-link" href="https://blog.kafol.net/">View all stories <span aria-hidden="true">→</span></a>
    </div>
    <div class="post-grid">
      {% for post in site.posts %}
      <article class="post-card" data-reveal style="--delay: {{ loop.index0 * 70 }}ms">
        <a href="{{ post.url }}">
          <p class="post-card__meta"><time>{{ post.date }}</time><span>{{ post.category }}</span></p>
          <h3>{{ post.title }}</h3>
          <p>{{ post.excerpt }}</p>
          <span class="post-card__arrow" aria-hidden="true">↗</span>
        </a>
      </article>
      {% endfor %}
    </div>
  </section>
</main>

<footer class="site-footer" id="contact">
  <div class="site-footer__inner shell">
    <div class="site-footer__brand">
      <span class="brand__name">Žan Kafol</span>
      <span class="brand__role">{{ site.eyebrow }}</span>
      <p>Stories from above the landscape<br>and beneath the karst.</p>
    </div>
    <div class="footer-group">
      <p class="footer-label">Contact</p>
      <a href="mailto:{{ site.email }}">{{ site.email }}</a>
      <span>{{ site.location }}</span>
    </div>
    <div class="footer-group">
      <p class="footer-label">Follow</p>
      <div class="footer-socials">
        {% for item in site.social %}<a href="{{ item.url }}" target="_blank" rel="noreferrer" aria-label="{{ item.label }}"><img src="{{ item.icon }}" alt=""></a>{% endfor %}
      </div>
    </div>
    <div class="site-footer__legal">
      <p>© {% year %} Žan Kafol</p>
      <a href="#top">Back to top ↑</a>
    </div>
  </div>
</footer>
