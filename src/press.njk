---
layout: layouts/base.njk
pagination:
  data: pressFeatures
  size: 1
  alias: pressItem
permalink: "{{ pressItem.permalink }}"
pressStyles: true
bodyClass: press-detail-page
eleventyComputed:
  title: "{{ pressItem.title }} — {{ pressItem.publication }}"
---
<header class="site-header" data-header>
  <a class="brand" href="/" aria-label="Žan Kafol, home">
    <span class="brand__name">Žan Kafol</span>
    <span class="brand__role">{{ site.eyebrow }}</span>
  </a>

  <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="site-nav">
    <span class="menu-toggle__label">Menu</span>
    <span class="menu-toggle__lines" aria-hidden="true"></span>
  </button>

  <nav class="site-nav" id="site-nav" aria-label="Primary navigation">
    <a href="/#work">Work</a>
    <a href="/#about">About</a>
    <a href="/#featured">Featured</a>
    <a href="/#press">Press</a>
    <a href="/#contact">Contact</a>
  </nav>
</header>

<main id="main" class="press-detail">
  <article>
    <header class="press-detail__header shell">
      <a class="press-detail__back" href="/#press">← Press &amp; interviews</a>
      <p class="section-label">Press archive</p>
      <h1>{{ pressItem.title }}</h1>
      <div class="press-detail__meta">
        <strong>{{ pressItem.publication }}</strong>
        <span>{{ pressItem.section }}</span>
        <time datetime="{{ pressItem.date }}">{{ pressItem.displayDate }}</time>
        <span>Words by {{ pressItem.byline }}</span>
        {% if pressItem.photoCredit %}<span>Photography by {{ pressItem.photoCredit }}</span>{% endif %}
      </div>
      <a class="press-detail__source" href="{{ pressItem.originalUrl }}" target="_blank" rel="noreferrer">
        {{ pressItem.originalLabel }} <span aria-hidden="true">↗</span>
      </a>
    </header>

    <figure class="press-detail__scan shell">
      <a href="{{ pressItem.scan }}" target="_blank" aria-label="Open article scan at full size">
        <img src="{{ pressItem.scan }}" alt="{{ pressItem.scanAlt }}" loading="eager" decoding="async">
      </a>
      <figcaption>Published in {{ pressItem.publication }} · Open the scan at full size</figcaption>
    </figure>
  </article>
</main>

<footer class="site-footer" id="contact">
  <div class="site-footer__inner shell">
    <div class="site-footer__brand">
      <span class="brand__name">Žan Kafol</span>
      <span class="brand__role">{{ site.eyebrow }}</span>
      <p>Photo stories shaped by flight,<br>caves and the karst landscape.</p>
    </div>
    <div class="footer-group">
      <p class="footer-label">Contact</p>
      <a href="mailto:{{ site.email }}">{{ site.email }}</a>
      <span>{{ site.location }}</span>
    </div>
    <div class="footer-group">
      <p class="footer-label">Follow</p>
      <div class="footer-socials">
        {% for item in site.social %}<a href="{{ item.url }}" target="_blank" rel="noreferrer" aria-label="{{ item.label }}"><img src="{{ item.icon }}" alt=""></a>{% endfor %}
      </div>
    </div>
    <div class="site-footer__legal">
      <p>© {% year %} Žan Kafol</p>
      <a href="/">Back home ↑</a>
    </div>
  </div>
</footer>
